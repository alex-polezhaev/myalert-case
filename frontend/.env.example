# Environment variables used by the MyAlert frontend (Vite).
# Create a local .env file in the project root (it is gitignored) and fill in
# the values below. Whenever a new env variable is introduced, add it here so
# the full list of required variables is always documented.

# Base URL of the MyAlert backend API.
VITE_API_URL=http://127.0.0.1

# Port the Vite dev server / frontend container listens on.
VITE_FRONTEND_PORT=66

# Telegram bot username used for the Telegram login widget and deep links.
VITE_BOT_NAME=your_telegram_bot

# Cookie domain for the auth cookie.
VITE_COOKIE_DOMAIN=127.0.0.1

# OAuth client id of your Avito application (used to start the Avito OAuth flow).
VITE_AVITO_CLIENT_ID=your_avito_client_id

# Environment mode: dev | prod
VITE_ENV=dev
