# ---------------------------------------------------------------------------
# Environment variables for the My Alert backend.
#
# Copy this file to `.env` in the repository root and fill in the values.
# `.env` is gitignored and must never be committed. Every container reads it
# via `env_file: .env` in docker-compose, so a single `.env` configures the
# whole mesh. Whenever you add a new variable in code, add it here too.
# All values below are placeholders.
# ---------------------------------------------------------------------------

# --- Web / CORS -------------------------------------------------------------
ORIGIN=https://my-alert.example          # Allowed frontend origin (CORS)
COOKIE_DOMAIN=my-alert.example           # Domain the session cookie is scoped to

# --- Service ports (each microservice listens on its own port) --------------
DOZZLE_PORT=8081                         # Dozzle log viewer
MONGO_DB_PORT=27017                      # Mongo database (mongod) exposed port
MONGO_PORT=3000                          # Mongo data-access service
AVITO_PORT=3001
TELEGRAM_PORT=3002
TASK_MANAGER_PORT=3003
MOOD_PORT=9005                           # MessageMood (Python sentiment service)
CONDUCTOR_PORT=3004
SECURITY_MONGO_PORT=3005
AUTH_PORT=3006
PAYMENT_PORT=3007

# --- Internal service hosts (base URLs used for service-to-service calls) ----
MONGO_HOST=http://mongo-server:3000
AVITO_HOST=http://avito:3001
TELEGRAM_HOST=http://telegram:3002
MOOD_HOST=http://message-mood:9005
AUTH_HOST=http://auth:3006
TINKOFF_HOST=https://securepay.tinkoff.ru
# Optional integrations referenced in code but not wired in this showcase:
GOOGLE_HOST=
YANDEX_HOST=
XML_HOST=
EMAIL_HOST=

# --- Mongo credentials ------------------------------------------------------
# Root credentials for the mongod container (MONGO_INITDB_ROOT_*).
MONGO_ROOT_USER=root
MONGO_ROOT_PASS=changeme_root
# Application DB user created by mongo-init.js for all app databases.
MONGO_USER=myalert
MONGO_PASS=changeme_app

# --- Mongo connection strings (one per logical database) --------------------
# Format: mongodb://<MONGO_USER>:<MONGO_PASS>@mongo-db:27017/<db>
MONGO_URL_BASE=mongodb://myalert:changeme_app@mongo-db:27017/base
MONGO_URL_AVITO=mongodb://myalert:changeme_app@mongo-db:27017/avito
MONGO_URL_TASKS=mongodb://myalert:changeme_app@mongo-db:27017/tasks
MONGO_URL_AUTH=mongodb://myalert:changeme_app@mongo-db:27017/base
MONGO_URL_PAYMENT=mongodb://myalert:changeme_app@mongo-db:27017/payment

# --- Telegram bot -----------------------------------------------------------
TG_BOT_TOKEN=000000000:AA_replace_with_your_telegram_bot_token

# --- Auth / sessions --------------------------------------------------------
SESSION_SECRET=replace_with_a_long_random_session_secret

# --- Tinkoff (T-Kassa) payments ---------------------------------------------
TINKOFF_TERM_KEY=replace_with_tinkoff_terminal_key
TINKOFF_TERM_PASS=replace_with_tinkoff_terminal_password

# --- Avito API (OAuth client credentials) -----------------------------------
AVITO_CLIENT_ID=replace_with_avito_client_id
AVITO_CLIENT_SECRET=replace_with_avito_client_secret

# ---------------------------------------------------------------------------
# Note: the MessageMood service relies on a FastText sentiment model
# (dostoevsky `fasttext-social-network-model`). It is large and gitignored —
# download it at build time inside the MessageMood container, it is not stored
# in this repository.
# ---------------------------------------------------------------------------
